{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aidenerdogan/pangolin-eval/schemas/report.v1.json",
  "title": "PangolinEval Report v1",
  "type": "object",
  "required": [
    "run_name",
    "description",
    "results",
    "summaries",
    "schema_version",
    "content_mode"
  ],
  "properties": {
    "run_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "schema_version": {
      "const": "pangolin-eval.report.v1"
    },
    "content_mode": {
      "enum": ["full", "metadata_only"]
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prompt_result"
      }
    },
    "summaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model_summary"
      }
    }
  },
  "$defs": {
    "prompt_result": {
      "type": "object",
      "required": [
        "prompt_id",
        "model_id",
        "response",
        "input_tokens",
        "output_tokens",
        "latency_ms",
        "estimated_cost_usd",
        "quality_score",
        "metadata"
      ],
      "properties": {
        "prompt_id": {
          "type": "string"
        },
        "model_id": {
          "type": "string"
        },
        "response": {
          "type": ["string", "null"],
          "description": "Model response text. Null when content_mode is metadata_only."
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "quality_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "model_summary": {
      "type": "object",
      "required": [
        "model_id",
        "runs",
        "avg_quality",
        "avg_latency_ms",
        "total_cost_usd",
        "efficiency_score",
        "recommendation"
      ],
      "properties": {
        "model_id": {
          "type": "string"
        },
        "runs": {
          "type": "integer",
          "minimum": 0
        },
        "avg_quality": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "avg_latency_ms": {
          "type": "number",
          "minimum": 0
        },
        "total_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "efficiency_score": {
          "type": ["number", "null"]
        },
        "recommendation": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
