{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aidenerdogan/pangolin-eval/schemas/report.v2.json",
  "title": "PangolinEval Report v2",
  "type": "object",
  "required": [
    "run_name",
    "description",
    "results",
    "summaries",
    "gate_results",
    "schema_version",
    "content_mode"
  ],
  "properties": {
    "run_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "schema_version": {
      "const": "pangolin-eval.report.v2"
    },
    "content_mode": {
      "enum": ["full", "metadata_only"]
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prompt_result"
      }
    },
    "summaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model_summary"
      }
    },
    "gate_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gate_result"
      }
    }
  },
  "$defs": {
    "prompt_result": {
      "type": "object",
      "required": [
        "prompt_id",
        "model_id",
        "response",
        "input_tokens",
        "output_tokens",
        "latency_ms",
        "estimated_cost_usd",
        "quality_score",
        "success",
        "status",
        "error",
        "retry_count",
        "timed_out",
        "usage_source",
        "metadata"
      ],
      "properties": {
        "prompt_id": {
          "type": "string"
        },
        "model_id": {
          "type": "string"
        },
        "response": {
          "type": ["string", "null"],
          "description": "Model response text. Null when content_mode is metadata_only or the provider call failed."
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "quality_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "success": {
          "type": "boolean"
        },
        "status": {
          "enum": ["success", "error", "timeout"]
        },
        "error": {
          "type": ["string", "null"]
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "timed_out": {
          "type": "boolean"
        },
        "usage_source": {
          "enum": ["estimated", "provider"]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "model_summary": {
      "type": "object",
      "required": [
        "model_id",
        "runs",
        "success_count",
        "failure_count",
        "success_rate",
        "avg_quality",
        "avg_latency_ms",
        "max_latency_ms",
        "total_cost_usd",
        "efficiency_score",
        "recommendation"
      ],
      "properties": {
        "model_id": {
          "type": "string"
        },
        "runs": {
          "type": "integer",
          "minimum": 0
        },
        "success_count": {
          "type": "integer",
          "minimum": 0
        },
        "failure_count": {
          "type": "integer",
          "minimum": 0
        },
        "success_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "avg_quality": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "avg_latency_ms": {
          "type": "number",
          "minimum": 0
        },
        "max_latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "total_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "efficiency_score": {
          "type": ["number", "null"]
        },
        "recommendation": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "gate_result": {
      "type": "object",
      "required": [
        "name",
        "passed",
        "actual",
        "threshold",
        "comparator",
        "scope",
        "message"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "actual": {
          "type": "number"
        },
        "threshold": {
          "type": "number"
        },
        "comparator": {
          "enum": ["<=", ">="]
        },
        "scope": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
