{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aidenerdogan/pangolin-eval/schemas/trace-events.v1.json",
  "title": "PangolinEval Trace Events v1",
  "type": "object",
  "required": ["schema_version", "traces"],
  "properties": {
    "schema_version": {
      "const": "pangolin-eval.trace_events.v1"
    },
    "run_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "traces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id", "outcome", "events"],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          },
          "events": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/event"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": ["id", "event_type", "name"],
      "properties": {
        "id": {
          "type": "string"
        },
        "event_type": {
          "enum": ["llm_call", "tool_call", "retry", "error", "cache_read", "cache_write", "substep"]
        },
        "name": {
          "type": "string"
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "success": {
          "type": "boolean"
        },
        "error": {
          "type": ["string", "null"]
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "cache_hit": {
          "type": "boolean"
        },
        "model_id": {
          "type": ["string", "null"]
        },
        "parent_id": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
