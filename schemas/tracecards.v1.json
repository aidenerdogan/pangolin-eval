{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aidenerdogan/pangolin-eval/schemas/tracecards.v1.json",
  "title": "PangolinEval TraceCards v1",
  "type": "object",
  "required": ["run_name", "description", "tracecards", "schema_version"],
  "properties": {
    "run_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "schema_version": {
      "const": "pangolin-eval.tracecards.v1"
    },
    "tracecards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tracecard"
      }
    }
  },
  "$defs": {
    "tracecard": {
      "type": "object",
      "required": [
        "task_id",
        "outcome",
        "success",
        "events",
        "total_cost_usd",
        "total_latency_ms",
        "input_tokens",
        "output_tokens",
        "retry_count",
        "failure_count",
        "cache_hit_count",
        "repeated_step_count",
        "cost_per_successful_task_usd"
      ],
      "properties": {
        "task_id": {
          "type": "string"
        },
        "outcome": {
          "type": "string"
        },
        "success": {
          "type": "boolean"
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "total_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "total_latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0
        },
        "failure_count": {
          "type": "integer",
          "minimum": 0
        },
        "cache_hit_count": {
          "type": "integer",
          "minimum": 0
        },
        "repeated_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "cost_per_successful_task_usd": {
          "type": ["number", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
